class RedFaucet
  VERSION: String

  class Error < StandardError
  end

  class AlreadyRecordingError < Error
  end

  class NotRecordingError < Error
  end

  class XPCError < Error
  end

  type event_type = :call | :return

  type raw_event_hash = {
    timestamp_ns: Integer,
    thread_id: Integer,
    event_type: event_type,
    probe_id: Integer,
    call_id: Integer,
    session_id: Integer
  }

  class RawEvent < Struct[untyped]
    attr_accessor timestamp_ns: Integer
    attr_accessor thread_id: Integer
    attr_accessor event_type: event_type
    attr_accessor probe_id: Integer
    attr_accessor call_id: Integer
    attr_accessor session_id: Integer
  end

  module RawStore
    class FormatError < StandardError
    end

    FORMAT: String
    VERSION: Integer
    EVENT_STRUCT_SIZE: Integer
    PACK_FMT: String

    def self.pack_record: (RawEvent) -> String
    def self.unpack_record: (String) -> RawEvent
    def self.dump: (IO, events: Array[RawEvent], meta: Hash[Symbol, untyped]) -> void
    def self.load: (IO) -> { meta: Hash[Symbol, untyped], events: Array[RawEvent] }
  end

  module OtelExporter
    SPAN_KIND_INTERNAL: Integer
    SERVICE_NAME: String

    def self.dump: (IO, events: Array[raw_event_hash], symbol_table: Hash[Integer, String], ?meta: Hash[Symbol, untyped]) -> void
    def self.build_document: (events: Array[raw_event_hash], symbol_table: Hash[Integer, String], ?meta: Hash[Symbol, untyped]) -> Hash[Symbol, untyped]
    def self.wrap_document: (Array[Hash[Symbol, untyped]]) -> Hash[Symbol, untyped]
    def self.build_spans: (events: Array[raw_event_hash], symbol_table: Hash[Integer, String], ?meta: Hash[Symbol, untyped]) -> Array[Hash[Symbol, untyped]]
  end

  def self.configure: (?mach_service_name: String?, ?ring_buffer_capacity: Integer) -> void
  def self.trace_method: (Module, Symbol | String) -> Integer
  def self.trace_all_instance_methods: (Module) -> void
  def self.untrace_method: (Module, Symbol | String) -> bool
  def self.open: () { () -> void } -> String

  def open: () -> self
  def stop: () -> String
end
